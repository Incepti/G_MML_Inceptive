# ─── GEEZ MML Studio — Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by default.

# ── LLM Configuration (required for prompt → MML generation) ─────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# ── Database (Neon Postgres) ─────────────────────────────────────────────
# On Vercel, this is auto-set when you link a Neon database.
# For local dev, create a free Neon project and copy the connection string.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Storage: S3-compatible (optional) ────────────────────────────────────
# Leave blank to disable uploads. Fill in for production.
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# For Cloudflare R2 or MinIO — set the custom endpoint:
S3_ENDPOINT=
S3_PUBLIC_URL=

# ── 3D Model Generation (optional — enables model-first pipeline) ────────
# Configure ONE provider. If none are set, the pipeline falls back to
# procedural building (primitives). Free tiers available for Meshy.ai.

# Meshy.ai (primary — meshy.ai/api)
MESHY_API_KEY=
# MESHY_API_ENDPOINT=https://api.meshy.ai/v2

# Stability AI (stability.ai)
# STABILITY_API_KEY=
# STABILITY_3D_ENDPOINT=https://api.stability.ai/v2beta/3d/stable-fast-3d

# TripoSR / Tripo3D (tripo3d.ai)
# TRIPOSR_API_KEY=
# TRIPOSR_API_ENDPOINT=https://api.tripo3d.ai/v2/openapi

# ── Rate Limiting ─────────────────────────────────────────────────────────
GENERATE_RATE_LIMIT=10

# ── Next.js ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NODE_ENV=development
