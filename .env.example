# ─── GEEZ MML Studio — Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by default.

# ── LLM Configuration (required for prompt → MML generation) ─────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# ── Database (Neon Postgres) ─────────────────────────────────────────────
# On Vercel, this is auto-set when you link a Neon database.
# For local dev, create a free Neon project and copy the connection string.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Storage: S3-compatible (optional) ────────────────────────────────────
# Leave blank to disable uploads. Fill in for production.
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# For Cloudflare R2 or MinIO — set the custom endpoint:
S3_ENDPOINT=
S3_PUBLIC_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────
GENERATE_RATE_LIMIT=10

# ── Next.js ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NODE_ENV=development
